# ─── Deploy Engine ────────────────────────────────────────────
# Bearer token for authenticating deployment requests.
# Generate a strong random token, e.g.: openssl rand -hex 32
DEPLOY_TOKEN=your-secret-token-here

# Port for the Deploy Engine API (default: 4000)
DEPLOY_ENGINE_PORT=4000

# Host binding — 127.0.0.1 ensures no external access
DEPLOY_ENGINE_HOST=127.0.0.1

# Path to SQLite database file
DATABASE_PATH=./data/deployments.db

# ─── Dashboard ────────────────────────────────────────────────
# Port for the Dashboard (default: 3000)
DASHBOARD_PORT=3000

# Engine URL as seen from the dashboard
# In Docker: http://deploy-engine:4000
# In dev:    http://127.0.0.1:4000
NEXT_PUBLIC_ENGINE_URL=http://127.0.0.1:4000
